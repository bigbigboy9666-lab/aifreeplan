---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import { readFileSync } from 'node:fs';
import { resolve } from 'node:path';

export function getStaticPaths() {
  const data = JSON.parse(readFileSync(resolve(process.cwd(), 'public/data/guides.json'), 'utf-8'));
  const guides = data.guides || [];
  return guides.map((guide) => ({
    params: { slug: guide.slug },
    props: { guide },
  }));
}

const { guide } = Astro.props;

const lang = 'zh';
const title = `${guide.title_zh} - AI Free Plan`;
const description = guide.excerpt_zh || guide.title_zh;

// Try to load static HTML content if it exists
let bodyContent = '';
const staticHtmlPath = resolve(process.cwd(), 'zh/guides', `${guide.slug}.html`);
try {
  const staticHtml = readFileSync(staticHtmlPath, 'utf-8');
  // Extract the <main> content between <main class="article-container"> and </main>
  const mainStart = staticHtml.indexOf('<main class="article-container">');
  const mainEnd = staticHtml.indexOf('</main>');
  if (mainStart !== -1 && mainEnd !== -1) {
    bodyContent = staticHtml.substring(mainStart + 31, mainEnd);
  }
} catch (e) {
  // No static HTML yet, will show placeholder
}
---

<BaseLayout title={title} description={description} lang={lang}>
  <div class="max-w-4xl mx-auto">
    <a href="/zh/guides" class="text-sm text-text-muted hover:text-primary mb-6 inline-block">&larr; 返回攻略列表</a>
    
    <h1 class="text-3xl font-bold mb-4">{guide.title_zh}</h1>
    <p class="text-text-muted mb-8">{guide.excerpt_zh}</p>

    <div class="prose prose-lg max-w-none">
      {bodyContent ? <div set:html={bodyContent} /> : <p class="text-text-muted">攻略内容待补充...</p>}
    </div>
  </div>
</BaseLayout>
