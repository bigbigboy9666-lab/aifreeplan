---
import BaseLayout from '../../layouts/BaseLayout.astro';

interface Guide {
  slug: string;
  title_zh: string;
  title_en: string;
  excerpt_zh?: string;
  excerpt_en?: string;
  pinned?: boolean;
  category?: string;
  date?: string;
}

import { readFileSync } from 'node:fs';
import { resolve } from 'node:path';

const guidesRaw = JSON.parse(readFileSync(resolve(process.cwd(), 'public/data/guides.json'), 'utf-8'));
const guides = guidesRaw.guides || [];

const lang = 'zh';
const title = 'AI 免费额度攻略 - AI Free Plan';
const description = '最新 AI 工具免费额度攻略，包括注册教程、白嫖方法、限时免费等信息。持续更新。';
---

<BaseLayout title={title} description={description} lang={lang}>
  <div class="max-w-4xl mx-auto">
    <h1 class="text-3xl font-bold mb-2">AI 免费额度攻略</h1>
    <p class="text-text-muted mb-8">最新 AI 工具免费额度攻略，持续更新中</p>

    <div class="space-y-4">
      {guides.filter(g => g.pinned).map((guide) => (
        <a href={`/zh/guides/${guide.slug}`} class="block p-5 rounded-xl border border-border hover:border-primary/30 hover:bg-primary/5 transition-all group">
          <div class="flex items-start justify-between gap-4">
            <div class="flex-1">
              <div class="flex items-center gap-2 mb-1">
                <span class="text-xs font-medium text-primary bg-primary/10 px-2 py-0.5 rounded">置顶</span>
                <h2 class="text-lg font-semibold group-hover:text-primary transition-colors">{guide.title_zh}</h2>
              </div>
              <p class="text-sm text-text-muted">{guide.excerpt_zh}</p>
            </div>
          </div>
        </a>
      ))}

      {guides.filter(g => !g.pinned).map((guide) => (
        <a href={`/zh/guides/${guide.slug}`} class="block p-5 rounded-xl border border-border hover:border-primary/30 hover:bg-primary/5 transition-all group">
          <div class="flex items-start justify-between gap-4">
            <div class="flex-1">
              <h2 class="text-lg font-semibold group-hover:text-primary transition-colors mb-1">{guide.title_zh}</h2>
              <p class="text-sm text-text-muted">{guide.excerpt_zh}</p>
            </div>
          </div>
        </a>
      ))}
    </div>
  </div>
</BaseLayout>
