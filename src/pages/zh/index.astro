---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ToolCard from '../../components/ToolCard.astro';
import GuideCard from '../../components/GuideCard.astro';
import ConversionBanner from '../../components/ConversionBanner.astro';
import { readFileSync } from 'fs';

const toolsData = JSON.parse(readFileSync('public/data/tools.json', 'utf-8'));
const tools = toolsData.tools || toolsData;
const categoriesData = JSON.parse(readFileSync('public/data/categories.json', 'utf-8'));
const categories = categoriesData.categories || categoriesData;
const guidesData = JSON.parse(readFileSync('public/data/guides.json', 'utf-8'));
const guides = guidesData.guides || [];

const lang = 'zh';
const topTools = tools.sort((a: any, b: any) => (b.rating || 0) - (a.rating || 0)).slice(0, 12);
const pinnedGuides = guides.filter((g: any) => g.pinned);
const recentGuides = guides.filter((g: any) => !g.pinned).slice(0, 6);
---

<BaseLayout
  title="AIFreePlan - AI免费额度聚合平台 | 发现最佳免费AI工具"
  description="全球首个AI工具免费额度聚合平台。汇总91款AI工具的免费额度、使用限制和白嫖攻略，帮你省钱用AI。"
  lang={lang}
>
  <!-- Hero Section -->
  <section class="relative bg-gradient-to-br from-emerald-50 to-indigo-50 dark:from-gray-900 dark:to-gray-800 py-20 px-4">
    <div class="max-w-6xl mx-auto text-center">
      <h1 class="text-4xl md:text-6xl font-bold mb-6 bg-gradient-to-r from-emerald-600 to-indigo-600 bg-clip-text text-transparent">
        AI免费额度聚合平台
      </h1>
      <p class="text-xl text-gray-600 dark:text-gray-300 mb-8 max-w-2xl mx-auto">
        汇总 {tools.length}+ 款AI工具的免费额度、使用限制和白嫖攻略。<br/>
        别再为选哪个AI工具纠结了，一张表帮你搞定。
      </p>
      <div class="flex flex-wrap justify-center gap-3">
        {categories.map((cat: any) => (
          <a href={`/${lang}/${cat.id}`}
             class="px-5 py-2.5 rounded-full bg-white dark:bg-gray-800 shadow-sm hover:shadow-md transition-all border border-gray-200 dark:border-gray-700 text-sm font-medium hover:border-emerald-400">
            {cat.icon} {cat.nameZh} ({cat.count})
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- Stats Bar -->
  <section class="bg-white dark:bg-gray-900 border-b border-gray-100 dark:border-gray-800 py-6">
    <div class="max-w-6xl mx-auto grid grid-cols-2 md:grid-cols-4 gap-4 text-center">
      <div>
        <div class="text-3xl font-bold text-emerald-600">{tools.length}</div>
        <div class="text-sm text-gray-500">收录工具</div>
      </div>
      <div>
        <div class="text-3xl font-bold text-indigo-600">{categories.length}</div>
        <div class="text-sm text-gray-500">工具分类</div>
      </div>
      <div>
        <div class="text-3xl font-bold text-amber-600">{tools.filter((t: any) => t.freeTier?.refreshPeriod === 'daily').length}</div>
        <div class="text-sm text-gray-500">每日刷新额度</div>
      </div>
      <div>
        <div class="text-3xl font-bold text-rose-600">{tools.filter((t: any) => !t.freeTier?.requiresCreditCard).length}</div>
        <div class="text-sm text-gray-500">免信用卡</div>
      </div>
    </div>
  </section>

  <!-- 最新攻略 -->
  <section class="max-w-6xl mx-auto px-4 py-16">
    <div class="flex items-center justify-between mb-8">
      <h2 class="text-3xl font-bold">🔥 最新攻略</h2>
      <a href="/zh/guides" class="text-primary font-medium hover:underline">
        查看全部攻略 →
      </a>
    </div>
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
      {pinnedGuides.map((guide: any) => (
        <GuideCard
          title={guide.title_zh}
          excerpt={guide.excerpt_zh}
          href={`/${lang}/guides/${guide.slug}`}
          pinned={true}
          lang={lang}
        />
      ))}
      {recentGuides.slice(0, 3).map((guide: any) => (
        <GuideCard
          title={guide.title_zh}
          excerpt={guide.excerpt_zh}
          href={`/${lang}/guides/${guide.slug}`}
          pinned={false}
          lang={lang}
        />
      ))}
    </div>
  </section>

  <!-- 热门免费AI工具 -->
  <section class="max-w-6xl mx-auto px-4 py-16">
    <h2 class="text-3xl font-bold mb-2">热门免费AI工具</h2>
    <p class="text-gray-500 mb-8">按评分排序，帮你快速找到最好用的免费工具</p>
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
      {topTools.map((tool: any) => (
        <ToolCard tool={tool} lang={lang} />
      ))}
    </div>
    <div class="text-center mt-10">
      <a href={`/${lang}/tools`}
         class="inline-flex items-center gap-2 px-8 py-3 bg-emerald-600 text-white rounded-lg hover:bg-emerald-700 transition-colors font-medium">
        查看全部 {tools.length} 个工具 →
      </a>
    </div>
  </section>

  <!-- 按分类浏览 -->
  <section class="bg-gray-50 dark:bg-gray-800/50 py-16 px-4">
    <div class="max-w-6xl mx-auto">
      <h2 class="text-3xl font-bold mb-8 text-center">按分类浏览</h2>
      <div class="grid grid-cols-2 md:grid-cols-3 gap-4">
        {categories.map((cat: any) => (
          <a href={`/${lang}/${cat.id}`}
             class="group bg-white dark:bg-gray-800 rounded-xl p-6 border border-gray-200 dark:border-gray-700 hover:border-emerald-400 hover:shadow-lg transition-all">
            <div class="text-4xl mb-3">{cat.icon}</div>
            <h3 class="text-lg font-bold mb-1 group-hover:text-emerald-600 transition-colors">
              {cat.nameZh}
            </h3>
            <p class="text-sm text-gray-500">{cat.count} 个工具</p>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- 为什么用AIFreePlan -->
  <section class="max-w-6xl mx-auto px-4 py-16">
    <h2 class="text-3xl font-bold mb-8 text-center">为什么要用 AIFreePlan？</h2>
    <div class="grid md:grid-cols-3 gap-8">
      <div class="text-center p-6">
        <div class="text-5xl mb-4">🔍</div>
        <h3 class="text-xl font-bold mb-2">额度透明</h3>
        <p class="text-gray-500">每个工具的免费额度、刷新周期、水印、商用权限全部透明展示，不玩文字游戏。</p>
      </div>
      <div class="text-center p-6">
        <div class="text-5xl mb-4">✅</div>
        <h3 class="text-xl font-bold mb-2">每周验证</h3>
        <p class="text-gray-500">自动化爬虫每周核对各平台定价页面，发现变更立即更新，保证信息不过时。</p>
      </div>
      <div class="text-center p-6">
        <div class="text-5xl mb-4">💰</div>
        <h3 class="text-xl font-bold mb-2">帮你省钱</h3>
        <p class="text-gray-500">同类工具横向对比，找到最适合你需求的免费方案，不再为不需要的功能付费。</p>
      </div>
    </div>
  </section>

  <!-- Submit CTA -->
  <section class="bg-gray-900 dark:bg-black py-16 px-4">
    <div class="max-w-4xl mx-auto text-center">
      <h2 class="text-3xl font-bold text-white mb-4">发现免费AI平台？提交推荐</h2>
      <p class="text-gray-400 mb-8 max-w-2xl mx-auto">
        如果你知道某个AI平台提供免费额度，欢迎提交推荐帮助我们完善数据库。
        每一条推荐都会经过人工审核，确保信息准确可靠。
      </p>
      <a href="mailto:submit@aifreeplan.com"
         class="inline-flex items-center gap-2 px-8 py-3 bg-emerald-600 text-white rounded-lg hover:bg-emerald-700 transition-colors font-medium">
        📩 提交推荐
      </a>
    </div>
  </section>

  <ConversionBanner lang={lang} />
</BaseLayout>
