---
import BaseLayout from '../../layouts/BaseLayout.astro';
import GuideCard from '../../components/GuideCard.astro';
import { readFileSync } from 'node:fs';
import { resolve } from 'node:path';

export function getStaticPaths() {
  const langs = ['zh', 'en'];
  return langs.map((lang) => ({
    params: { lang },
    props: { lang },
  }));
}

const { lang } = Astro.props as { lang: 'zh' | 'en' };
const isZh = lang === 'zh';

const guidesData = JSON.parse(readFileSync(resolve(process.cwd(), 'public/data/guides.json'), 'utf-8'));
const guides = (guidesData.guides || []).sort((a: any, b: any) => {
  if ((a.pinned || false) !== (b.pinned || false)) {
    return (b.pinned || false) ? 1 : -1;
  }
  return (b.date || '').localeCompare(a.date || '');
});

const pinnedGuides = guides.filter((g: any) => g.pinned);
const otherGuides = guides.filter((g: any) => !g.pinned);

const title = isZh
  ? 'AI 免费额度攻略 - AI Free Plan'
  : 'AI Free Tier Guides - AI Free Plan';
const description = isZh
  ? '最新 AI 工具免费额度攻略，包括注册教程、白嫖方法、限时免费等信息。持续更新。'
  : 'Latest guides on AI tool free tiers, including registration tutorials, free methods, and limited-time offers. Updated regularly.';

const canonicalUrl = `https://aifreeplan.com/${lang}/guides/`;
---

<BaseLayout
  title={title}
  description={description}
  canonicalUrl={canonicalUrl}
  lang={lang}
>
  <div class="max-w-4xl mx-auto">
    <h1 class="text-3xl font-bold mb-2">{isZh ? 'AI 免费额度攻略' : 'AI Free Tier Guides'}</h1>
    <p class="text-text-muted mb-8">{isZh ? '最新 AI 工具免费额度攻略，持续更新中' : 'Latest guides on AI tool free tiers, updated regularly'}</p>

    <div class="space-y-4">
      {pinnedGuides.map((guide: any) => (
        <a href={`/${lang}/guides/${guide.slug}`} class="block p-5 rounded-xl border border-border hover:border-primary/30 hover:bg-primary/5 transition-all group">
          <div class="flex items-start justify-between gap-4">
            <div class="flex-1">
              <div class="flex items-center gap-2 mb-1">
                <span class="text-xs font-medium text-primary bg-primary/10 px-2 py-0.5 rounded">{isZh ? '置顶' : 'Pinned'}</span>
                <h2 class="text-lg font-semibold group-hover:text-primary transition-colors">{isZh ? guide.title_zh : guide.title_en}</h2>
              </div>
              <p class="text-sm text-text-muted">{isZh ? guide.excerpt_zh : guide.excerpt_en}</p>
            </div>
          </div>
        </a>
      ))}

      {otherGuides.map((guide: any) => (
        <a href={`/${lang}/guides/${guide.slug}`} class="block p-5 rounded-xl border border-border hover:border-primary/30 hover:bg-primary/5 transition-all group">
          <div class="flex items-start justify-between gap-4">
            <div class="flex-1">
              <h2 class="text-lg font-semibold group-hover:text-primary transition-colors mb-1">{isZh ? guide.title_zh : guide.title_en}</h2>
              <p class="text-sm text-text-muted">{isZh ? guide.excerpt_zh : guide.excerpt_en}</p>
            </div>
          </div>
        </a>
      ))}
    </div>
  </div>
</BaseLayout>

