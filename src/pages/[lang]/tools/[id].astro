---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import FreeCreditsBox from '../../../components/FreeCreditsBox.astro';
import ConversionBanner from '../../../components/ConversionBanner.astro';
import ToolCard from '../../../components/ToolCard.astro';
import type { AITool } from '../../../types';
import { readFileSync } from 'node:fs';
import { resolve } from 'node:path';

const siteUrl = 'https://aifreeplan.com';

export function getStaticPaths() {
  const data = JSON.parse(readFileSync(resolve(process.cwd(), 'public/data/tools.json'), 'utf-8'));
  const langs = ['zh', 'en'];
  return langs.flatMap((lang) =>
    data.tools.map((tool: any) => ({
      params: { lang, id: tool.id },
      props: { tool },
    }))
  );
}

const { lang } = Astro.params as { lang: 'zh' | 'en' };
const { tool } = Astro.props as { tool: AITool };

// Read all tools for related section
const allToolsData = JSON.parse(readFileSync(resolve(process.cwd(), 'public/data/tools.json'), 'utf-8'));
const allTools: AITool[] = allToolsData.tools as AITool[];

// Language-aware content
const name = lang === 'zh' ? tool.name : tool.nameEn;
const description = lang === 'zh' ? tool.description : tool.descriptionEn;
const category = lang === 'zh' ? tool.categoryZh : tool.categoryEn;
const categorySlug = tool.category.toLowerCase();
const paidFrom = lang === 'zh' ? tool.paidFrom : tool.paidFromEn;
const pros = lang === 'zh' ? tool.pros : tool.prosEn;
const cons = lang === 'zh' ? tool.cons : tool.consEn;
const features = lang === 'zh' ? tool.features : tool.featuresEn;
const tips = lang === 'zh' ? tool.tips : tool.tipsEn;

// SEO — data uses title (English) and titleZh (Chinese)
const seoTitle = lang === 'zh'
  ? (tool.seoMeta.titleZh || tool.seoMeta.title)
  : tool.seoMeta.title;
const seoDesc = lang === 'zh'
  ? (tool.seoMeta.descriptionZh || tool.seoMeta.description)
  : tool.seoMeta.description;

const canonicalUrl = `${siteUrl}/${lang}/tools/${tool.id}`;

// Rating stars
const fullStars = Math.floor(tool.rating);
const hasHalf = tool.rating % 1 >= 0.5;
const emptyStars = 5 - fullStars - (hasHalf ? 1 : 0);

// Related tools (same category, exclude current)
const relatedTools = allTools
  .filter(t => t.category === tool.category && t.id !== tool.id)
  .slice(0, 4);

// JSON-LD: SoftwareApplication
const softwareSchema = {
  "@context": "https://schema.org",
  "@type": "SoftwareApplication",
  "name": tool.nameEn || tool.name,
  "alternateName": tool.name,
  "description": lang === 'zh' ? tool.description : tool.descriptionEn,
  "applicationCategory": category,
  "operatingSystem": "Web",
  "url": tool.websiteUrl,
  "offers": {
    "@type": "Offer",
    "price": "0",
    "priceCurrency": "USD",
    "description": lang === 'zh'
      ? `免费额度: ${tool.freeTier.credits} ${tool.freeTier.creditUnit}`
      : `Free credits: ${tool.freeTier.credits} ${tool.freeTier.creditUnit}`
  },
  "aggregateRating": {
    "@type": "AggregateRating",
    "ratingValue": tool.rating.toString(),
    "bestRating": "5",
    "worstRating": "1",
    "ratingCount": "1"
  },
  "author": {
    "@type": "Organization",
    "name": tool.company
  }
};

// JSON-LD: BreadcrumbList
const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    {
      "@type": "ListItem",
      "position": 1,
      "name": lang === 'zh' ? '首页' : 'Home',
      "item": `${siteUrl}/${lang}`
    },
    {
      "@type": "ListItem",
      "position": 2,
      "name": category,
      "item": `${siteUrl}/${lang}/${categorySlug}`
    },
    {
      "@type": "ListItem",
      "position": 3,
      "name": name,
      "item": canonicalUrl
    }
  ]
};

// JSON-LD: FAQPage
const refreshText: Record<string, Record<string, string>> = {
  daily: { zh: '每日刷新', en: 'refreshing daily' },
  weekly: { zh: '每周刷新', en: 'refreshing weekly' },
  monthly: { zh: '每月刷新', en: 'refreshing monthly' },
  'one-time': { zh: '一次性', en: 'one-time only' },
  unknown: { zh: '未知', en: 'unknown' },
};

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": lang === 'zh'
        ? `${name}的免费额度是多少？`
        : `What are ${tool.nameEn || tool.name}'s free credits?`,
      "acceptedAnswer": {
        "@type": "Answer",
        "text": lang === 'zh'
          ? `${name}提供 ${tool.freeTier.credits} ${tool.freeTier.creditUnit}，${refreshText[tool.freeTier.refreshPeriod]?.zh || '未知'}。`
          : `${tool.nameEn || tool.name} offers ${tool.freeTier.credits} ${tool.freeTier.creditUnit}, ${refreshText[tool.freeTier.refreshPeriod]?.en || 'unknown'}.`
      }
    },
    {
      "@type": "Question",
      "name": lang === 'zh'
        ? `${name}需要信用卡吗？`
        : `Does ${tool.nameEn || tool.name} require a credit card?`,
      "acceptedAnswer": {
        "@type": "Answer",
        "text": tool.freeTier.requiresCreditCard
          ? (lang === 'zh' ? '是的，注册需要绑定信用卡。' : 'Yes, a credit card is required to sign up.')
          : (lang === 'zh' ? '不需要，注册即可使用免费额度。' : 'No, you can start using the free tier without a credit card.')
      }
    },
    {
      "@type": "Question",
      "name": lang === 'zh'
        ? `${name}免费版有水印吗？`
        : `Does ${tool.nameEn || tool.name}'s free tier include watermarks?`,
      "acceptedAnswer": {
        "@type": "Answer",
        "text": tool.freeTier.watermark
          ? (lang === 'zh' ? '免费版输出带有水印，付费版可去除。' : 'Yes, free tier outputs include watermarks. Remove them with a paid plan.')
          : (lang === 'zh' ? '免费版输出没有水印。' : 'No, the free tier produces watermark-free output.')
      }
    }
  ]
};

const jsonLd = [softwareSchema, breadcrumbSchema, faqSchema];
---

<BaseLayout
  title={seoTitle}
  description={seoDesc}
  canonicalUrl={canonicalUrl}
  jsonLd={jsonLd}
  lang={lang}
>
  <!-- Breadcrumb Navigation -->
  <nav class="flex items-center gap-2 text-sm text-text-muted mb-6 flex-wrap" aria-label="Breadcrumb">
    <a href={`/${lang}`} class="hover:text-primary">{lang === 'zh' ? '首页' : 'Home'}</a>
    <span>/</span>
    <a href={`/${lang}/${categorySlug}`} class="hover:text-primary">{category}</a>
    <span>/</span>
    <span class="text-text font-medium">{name}</span>
  </nav>

  <!-- Hero Section -->
  <div class="mb-8">
    <div class="flex flex-col sm:flex-row sm:items-start sm:justify-between gap-4 mb-4">
      <div class="flex-1">
        <h1 class="text-3xl sm:text-4xl font-bold mb-2">{name}</h1>
        <div class="flex items-center gap-3 flex-wrap">
          <span class="inline-block px-3 py-1 text-sm rounded-full bg-primary/10 text-primary">
            {category}
          </span>
          <span class="text-sm text-text-muted">
            {lang === 'zh' ? '由' : 'by'} <span class="font-medium text-text">{tool.company}</span>
          </span>
        </div>
      </div>
      <div class="flex items-center gap-1 shrink-0" aria-label={`${tool.rating} / 5`}>
        {Array.from({ length: fullStars }).map(() => (
          <span class="text-accent text-xl">★</span>
        ))}
        {hasHalf && <span class="text-accent text-xl">★</span>}
        {Array.from({ length: emptyStars }).map(() => (
          <span class="text-gray-300 text-xl">★</span>
        ))}
        <span class="text-sm font-semibold text-text ml-1">{tool.rating}</span>
      </div>
    </div>

    <p class="text-lg text-text-muted leading-relaxed">{description}</p>

    <div class="mt-4 flex flex-wrap gap-3">
      <a
        href={tool.websiteUrl}
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex items-center gap-2 bg-primary text-white text-sm font-medium rounded-lg px-5 py-2.5 hover:bg-primary-dark transition-colors"
      >
        {lang === 'zh' ? '访问官网' : 'Visit Website'}
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
        </svg>
      </a>
      {tool.affiliateUrl && (
        <a
          href={tool.affiliateUrl}
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-2 bg-secondary text-white text-sm font-medium rounded-lg px-5 py-2.5 hover:opacity-90 transition-opacity"
        >
          {lang === 'zh' ? '专属链接' : 'Affiliate Link'}
        </a>
      )}
      {paidFrom && (
        <span class="inline-flex items-center text-sm text-text-muted bg-white border border-border rounded-lg px-4 py-2.5">
          {lang === 'zh' ? '付费起步' : 'Paid from'}: <span class="font-semibold text-text ml-1">{paidFrom}</span>
        </span>
      )}
    </div>
  </div>

  <!-- Free Tier Details -->
  <section class="mb-8">
    <FreeCreditsBox tool={tool} lang={lang} />
  </section>

  <!-- Pros & Cons -->
  <section class="mb-8">
    <h2 class="text-2xl font-bold mb-4">
      {lang === 'zh' ? '👍👎 优缺点' : '👍👎 Pros & Cons'}
    </h2>
    <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
      <!-- Pros -->
      <div class="bg-green-50 border border-green-200 rounded-xl p-5">
        <h3 class="text-lg font-bold text-green-700 mb-3">
          ✅ {lang === 'zh' ? '优点' : 'Pros'}
        </h3>
        <ul class="space-y-2">
          {pros.map((pro) => (
            <li class="flex items-start gap-2 text-sm">
              <span class="text-green-500 mt-0.5 shrink-0">+</span>
              <span class="text-text">{pro}</span>
            </li>
          ))}
        </ul>
      </div>

      <!-- Cons -->
      <div class="bg-red-50 border border-red-200 rounded-xl p-5">
        <h3 class="text-lg font-bold text-red-700 mb-3">
          ❌ {lang === 'zh' ? '缺点' : 'Cons'}
        </h3>
        <ul class="space-y-2">
          {cons.map((con) => (
            <li class="flex items-start gap-2 text-sm">
              <span class="text-red-500 mt-0.5 shrink-0">-</span>
              <span class="text-text">{con}</span>
            </li>
          ))}
        </ul>
      </div>
    </div>
  </section>

  <!-- Features -->
  <section class="mb-8">
    <h2 class="text-2xl font-bold mb-4">
      {lang === 'zh' ? '🎯 核心功能' : '🎯 Key Features'}
    </h2>
    <div class="flex flex-wrap gap-2">
      {features.map((feature) => (
        <span class="inline-block bg-primary/10 text-primary text-sm font-medium px-3 py-1.5 rounded-full">
          {feature}
        </span>
      ))}
    </div>
  </section>

  <!-- Tips -->
  <section class="mb-8">
    <h2 class="text-2xl font-bold mb-4">
      {lang === 'zh' ? '💡 使用技巧' : '💡 Tips & Tricks'}
    </h2>
    <div class="bg-amber-50 border border-amber-200 rounded-xl p-5">
      <ul class="space-y-3">
        {tips.map((tip, i) => (
          <li class="flex items-start gap-3 text-sm">
            <span class="bg-amber-400 text-white text-xs font-bold w-6 h-6 rounded-full flex items-center justify-center shrink-0 mt-0.5">
              {i + 1}
            </span>
            <span class="text-text">{tip}</span>
          </li>
        ))}
      </ul>
    </div>
  </section>

  <!-- Last Verified & Report -->
  <section class="mb-8">
    <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-3 bg-white border border-border rounded-xl p-4">
      <div class="flex items-center gap-2 text-sm text-text-muted">
        <span>📅</span>
        <span>
          {lang === 'zh' ? '最后验证日期:' : 'Last verified:'}
          <span class="font-medium text-text">{tool.lastVerifiedDate}</span>
        </span>
      </div>
      <a
        href={`mailto:report@aifreeplan.com?subject=${encodeURIComponent(`[${lang === 'zh' ? '信息过时' : 'Report Outdated'}] ${name} (${tool.id})`)}&body=${encodeURIComponent(lang === 'zh' ? `工具: ${name}\nID: ${tool.id}\n请描述过时信息:` : `Tool: ${name}\nID: ${tool.id}\nPlease describe the outdated information:`)}`}
        class="inline-flex items-center gap-2 text-sm text-accent hover:underline"
      >
        <span>🚩</span>
        {lang === 'zh' ? '报告信息过时' : 'Report Outdated Info'}
      </a>
    </div>
  </section>

  <!-- Related Tools -->
  {relatedTools.length > 0 && (
    <section class="mb-8">
      <h2 class="text-2xl font-bold mb-4">
        {lang === 'zh' ? `🔗 相关${category}工具` : `🔗 Related ${category} Tools`}
      </h2>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4">
        {relatedTools.map((related) => (
          <ToolCard tool={related} lang={lang} />
        ))}
      </div>
    </section>
  )}

  <!-- Conversion Banner -->
  <ConversionBanner lang={lang} />
</BaseLayout>
