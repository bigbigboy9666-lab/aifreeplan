---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ToolCard from '../../components/ToolCard.astro';
import GuideCard from '../../components/GuideCard.astro';
import ConversionBanner from '../../components/ConversionBanner.astro';
import { readFileSync } from 'fs';

const toolsData = JSON.parse(readFileSync('public/data/tools.json', 'utf-8'));
const tools = toolsData.tools || toolsData;
const categoriesData = JSON.parse(readFileSync('public/data/categories.json', 'utf-8'));
const categories = categoriesData.categories || categoriesData;
const guidesData = JSON.parse(readFileSync('public/data/guides.json', 'utf-8'));
const guides = guidesData.guides || [];

const lang = 'en';
const topTools = tools.sort((a: any, b: any) => (b.rating || 0) - (a.rating || 0)).slice(0, 12);
const pinnedGuides = guides.filter((g: any) => g.pinned);
const recentGuides = guides.filter((g: any) => !g.pinned).slice(0, 6);
---

<BaseLayout
  title="AIFreePlan - AI Free Tier Aggregator | Find the Best Free AI Tools"
  description="The world's first AI free tier aggregation platform. Compare free credits, usage limits, and trial details across 91 AI tools."
  lang={lang}
>
  <section class="relative bg-gradient-to-br from-emerald-50 to-indigo-50 dark:from-gray-900 dark:to-gray-800 py-20 px-4">
    <div class="max-w-6xl mx-auto text-center">
      <h1 class="text-4xl md:text-6xl font-bold mb-6 bg-gradient-to-r from-emerald-600 to-indigo-600 bg-clip-text text-transparent">
        AI Free Tier Aggregator
      </h1>
      <p class="text-xl text-gray-600 dark:text-gray-300 mb-8 max-w-2xl mx-auto">
        Compare free credits, limits, and trial details across {tools.length}+ AI tools.<br/>
        Stop guessing — find the best free AI tools with one click.
      </p>
      <div class="flex flex-wrap justify-center gap-3">
        {categories.map((cat: any) => (
          <a href={`/${lang}/${cat.id}`}
             class="px-5 py-2.5 rounded-full bg-white dark:bg-gray-800 shadow-sm hover:shadow-md transition-all border border-gray-200 dark:border-gray-700 text-sm font-medium hover:border-emerald-400">
            {cat.icon} {cat.nameEn} ({cat.count})
          </a>
        ))}
      </div>
    </div>
  </section>

  <section class="bg-white dark:bg-gray-900 border-b border-gray-100 dark:border-gray-800 py-6">
    <div class="max-w-6xl mx-auto grid grid-cols-2 md:grid-cols-4 gap-4 text-center">
      <div>
        <div class="text-3xl font-bold text-emerald-600">{tools.length}</div>
        <div class="text-sm text-gray-500">Tools Listed</div>
      </div>
      <div>
        <div class="text-3xl font-bold text-indigo-600">{categories.length}</div>
        <div class="text-sm text-gray-500">Categories</div>
      </div>
      <div>
        <div class="text-3xl font-bold text-amber-600">{tools.filter((t: any) => t.freeTier?.refreshPeriod === 'daily').length}</div>
        <div class="text-sm text-gray-500">Daily Refresh</div>
      </div>
      <div>
        <div class="text-3xl font-bold text-rose-600">{tools.filter((t: any) => !t.freeTier?.requiresCreditCard).length}</div>
        <div class="text-sm text-gray-500">No Credit Card</div>
      </div>
    </div>
  </section>

  <!-- Latest Guides -->
  <section class="max-w-6xl mx-auto px-4 py-16">
    <div class="flex items-center justify-between mb-8">
      <h2 class="text-3xl font-bold">📚 Latest Guides</h2>
      <a href="/en/guides" class="text-primary font-medium hover:underline">
        View All Guides →
      </a>
    </div>
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
      {pinnedGuides.map((guide: any) => (
        <GuideCard
          title={guide.title_en}
          excerpt={guide.excerpt_en}
          href={`/${lang}/guides/${guide.slug}`}
          pinned={true}
          lang={lang}
        />
      ))}
      {recentGuides.slice(0, 8).map((guide: any) => (
        <GuideCard
          title={guide.title_en}
          excerpt={guide.excerpt_en}
          href={`/${lang}/guides/${guide.slug}`}
          pinned={false}
          lang={lang}
        />
      ))}
    </div>
  </section>

  <section class="max-w-6xl mx-auto px-4 py-16">
    <h2 class="text-3xl font-bold mb-2">Top Free AI Tools</h2>
    <p class="text-gray-500 mb-8">Sorted by rating — find the best free tools fast</p>
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
      {topTools.map((tool: any) => (
        <ToolCard tool={tool} lang={lang} />
      ))}
    </div>
    <div class="text-center mt-10">
      <a href={`/${lang}/tools`}
         class="inline-flex items-center gap-2 px-8 py-3 bg-emerald-600 text-white rounded-lg hover:bg-emerald-700 transition-colors font-medium">
        View All {tools.length} Tools →
      </a>
    </div>
  </section>

  <section class="bg-gray-50 dark:bg-gray-800/50 py-16 px-4">
    <div class="max-w-6xl mx-auto">
      <h2 class="text-3xl font-bold mb-8 text-center">Browse by Category</h2>
      <div class="grid grid-cols-2 md:grid-cols-3 gap-4">
        {categories.map((cat: any) => (
          <a href={`/${lang}/${cat.id}`}
             class="group bg-white dark:bg-gray-800 rounded-xl p-6 border border-gray-200 dark:border-gray-700 hover:border-emerald-400 hover:shadow-lg transition-all h-full flex flex-col">
            <div class="text-4xl mb-3">{cat.icon}</div>
            <h3 class="text-lg font-bold mb-1 group-hover:text-emerald-600 transition-colors">
              {cat.nameEn}
            </h3>
            <p class="text-sm text-gray-500 mt-auto">{cat.count} tools</p>
          </a>
        ))}
      </div>
    </div>
  </section>

  <section class="max-w-6xl mx-auto px-4 py-16">
    <h2 class="text-3xl font-bold mb-8 text-center">Why AIFreePlan?</h2>
    <div class="grid md:grid-cols-3 gap-8">
      <div class="text-center p-6">
        <div class="text-5xl mb-4">🔍</div>
        <h3 class="text-xl font-bold mb-2">Transparent Credits</h3>
        <p class="text-gray-500">Every tool's free tier, refresh cycle, watermark policy, and commercial use rights — all clearly displayed.</p>
      </div>
      <div class="text-center p-6">
        <div class="text-5xl mb-4">✅</div>
        <h3 class="text-xl font-bold mb-2">Weekly Verified</h3>
        <p class="text-gray-500">Automated scrapers verify pricing pages weekly. Changes are detected and updated automatically.</p>
      </div>
      <div class="text-center p-6">
        <div class="text-5xl mb-4">💰</div>
        <h3 class="text-xl font-bold mb-2">Save Money</h3>
        <p class="text-gray-500">Side-by-side comparisons help you find the best free plan for your needs — no more paying for features you don't use.</p>
      </div>
    </div>
  </section>

  <!-- Submit CTA -->
  <section class="bg-gray-900 dark:bg-black py-16 px-4">
    <div class="max-w-4xl mx-auto text-center">
      <h2 class="text-3xl font-bold text-white mb-4">Know a Free AI Platform? Submit a Recommendation</h2>
      <p class="text-gray-400 mb-8 max-w-2xl mx-auto">
        If you know of an AI platform offering free credits, help us expand our database.
        Every submission is manually reviewed to ensure accuracy and reliability.
      </p>
      <a href="mailto:submit@aifreeplan.com?subject=Tool+Recommendation&body=Tool+Name%3A%0AURL%3A%0AFree+Quota%3A%0ANotes%3A"
         class="inline-flex items-center gap-2 px-8 py-3 bg-emerald-600 text-white rounded-lg hover:bg-emerald-700 transition-colors font-medium">
        📩 Submit Recommendation
      </a>
    </div>
  </section>

  <ConversionBanner lang={lang} />
</BaseLayout>
