---
import BaseLayout from '../../layouts/BaseLayout.astro';

interface Guide {
  slug: string;
  title_zh: string;
  title_en: string;
  excerpt_zh?: string;
  excerpt_en?: string;
  pinned?: boolean;
  category?: string;
  date?: string;
}

import { readFileSync } from 'node:fs';
import { resolve } from 'node:path';

const guidesRaw = JSON.parse(readFileSync(resolve(process.cwd(), 'public/data/guides.json'), 'utf-8'));
const guides = guidesRaw.guides || [];

const lang = 'en';
const title = 'AI Free Tier Guides - AI Free Plan';
const description = 'Latest guides on AI tool free tiers, including registration tutorials, free methods, and limited-time offers. Updated regularly.';
---

<BaseLayout title={title} description={description} lang={lang}>
  <div class="max-w-4xl mx-auto">
    <h1 class="text-3xl font-bold mb-2">AI Free Tier Guides</h1>
    <p class="text-text-muted mb-8">Latest guides on AI tool free tiers, updated regularly</p>

    <div class="space-y-4">
      {guides.filter(g => g.pinned).map((guide) => (
        <a href={`/en/guides/${guide.slug}`} class="block p-5 rounded-xl border border-border hover:border-primary/30 hover:bg-primary/5 transition-all group">
          <div class="flex items-start justify-between gap-4">
            <div class="flex-1">
              <div class="flex items-center gap-2 mb-1">
                <span class="text-xs font-medium text-primary bg-primary/10 px-2 py-0.5 rounded">Pinned</span>
                <h2 class="text-lg font-semibold group-hover:text-primary transition-colors">{guide.title_en}</h2>
              </div>
              <p class="text-sm text-text-muted">{guide.excerpt_en}</p>
            </div>
          </div>
        </a>
      ))}

      {guides.filter(g => !g.pinned).map((guide) => (
        <a href={`/en/guides/${guide.slug}`} class="block p-5 rounded-xl border border-border hover:border-primary/30 hover:bg-primary/5 transition-all group">
          <div class="flex items-start justify-between gap-4">
            <div class="flex-1">
              <h2 class="text-lg font-semibold group-hover:text-primary transition-colors mb-1">{guide.title_en}</h2>
              <p class="text-sm text-text-muted">{guide.excerpt_en}</p>
            </div>
          </div>
        </a>
      ))}
    </div>
  </div>
</BaseLayout>
