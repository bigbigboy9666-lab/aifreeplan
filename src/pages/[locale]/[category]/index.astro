---
import { getTools } from '@/utils/data';
import BaseLayout from '@/layouts/BaseLayout.astro';
import Breadcrumb from '@/components/Breadcrumb.astro';
import ToolCard from '@/components/ToolCard.astro';
import { CATEGORIES } from '@/utils/categories';

export function getStaticPaths() {
  const categories = Object.keys(CATEGORIES);
  const locales = ['zh', 'en'];
  const tools = getTools();

  return locales.flatMap((locale) =>
    categories.map((category) => ({
      params: { locale, category },
      props: {
        tools: tools.filter((t) => t.data.category === category),
        category,
        locale,
      },
    }))
  );
}

const { tools, category, locale } = Astro.props;
const isZh = locale === 'zh';
const catInfo = CATEGORIES[category] || { zh: category, en: category, emoji: '📦' };
const catName = isZh ? catInfo.zh : catInfo.en;

const title = `${catName} | AIFreePlan`;
const description = isZh
  ? `${catName}免费额度对比评测：共${tools.length}个工具实测，含免费额度、重置周期、水印政策、商用许可等详细信息。`
  : `${catName} free tier comparison: ${tools.length} tools tested with credits, reset cycle, watermark & commercial use details.`;

const siteUrl = `https://aifreeplan.com/${locale}`;
const jsonLd = [
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      { "@type": "ListItem", "position": 1, "name": "AIFreePlan", "item": `https://aifreeplan.com/${locale}` },
      { "@type": "ListItem", "position": 2, "name": catName, "item": `${siteUrl}/${category}` }
    ]
  },
  {
    "@context": "https://schema.org",
    "@type": "ItemList",
    "name": catName,
    "url": `${siteUrl}/${category}`,
    "numberOfItems": tools.length,
    "itemListElement": tools.map((tool, i) => ({
      "@type": "ListItem",
      "position": i + 1,
      "url": `${siteUrl}/${category}/${tool.data.slug}`
    }))
  }
];
---

<BaseLayout
  title={title}
  description={description}
  locale={locale}
  canonical={`https://aifreeplan.com/${locale}/${category}`}
  currentPath={`/${locale}/${category}`}
  jsonLd={jsonLd}
>
  <Breadcrumb items={[{ label: catName }]} locale={locale} />

  <header class="guide-header">
    <h1>{catInfo.emoji} {catName}</h1>
    <p>{isZh ? `共 ${tools.length} 个工具` : `${tools.length} tools`}</p>
  </header>

  <div class="tools-grid">
    {tools.map((tool) => (
      <ToolCard tool={tool.data} locale={locale} />
    ))}
  </div>
</BaseLayout>
