---
import BaseLayout from '@/layouts/BaseLayout.astro';
import Breadcrumb from '@/components/Breadcrumb.astro';

export async function getStaticPaths() {
  return [
    { params: { locale: 'zh' } },
    { params: { locale: 'en' } },
  ];
}

const { locale } = Astro.params;
const isZh = locale === 'zh';

const title = isZh ? '隐私政策 | AIFreePlan' : 'Privacy Policy | AIFreePlan';
const description = isZh ? 'AIFreePlan隐私政策' : 'AIFreePlan Privacy Policy';
---

<BaseLayout
  title={title}
  description={description}
  locale={locale}
  canonical={`https://aifreeplan.com/${locale}/privacy/`}
  currentPath={`/${locale}/privacy/`}
>
  <Breadcrumb items={[{ label: isZh ? '隐私政策' : 'Privacy Policy' }]} locale={locale} />
  <article class="guide-detail">
    <section class="guide-content">
      <p>{isZh ? '请查看我们的隐私政策页面。' : 'Please see our privacy policy page.'}</p>
      <p><a href={`/privacy-${locale}.html`} target="_blank">{isZh ? '查看完整隐私政策' : 'View full privacy policy'}</a></p>
    </section>
  </article>
</BaseLayout>
