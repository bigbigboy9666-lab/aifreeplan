---
import '../styles/global.css';

interface Props {
  title: string;
  description: string;
  canonicalUrl?: string;
  jsonLd?: Record<string, any> | Record<string, any>[];
  lang?: 'zh' | 'en';
}

const {
  title,
  description,
  canonicalUrl,
  jsonLd,
  lang = 'zh',
} = Astro.props;

const siteUrl = 'https://aifreeplan.com';
const currentPath = Astro.url.pathname;
const zhUrl = `${siteUrl}${currentPath.replace(/^\/en/, '/zh')}`;
const enUrl = `${siteUrl}${currentPath.replace(/^\/zh/, '/en')}`;
const canonical = canonicalUrl || `${siteUrl}${currentPath}`;
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="robots" content="index, follow" />
    <link rel="canonical" href={canonical} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <!-- hreflang tags -->
    <link rel="alternate" hreflang="zh" href={zhUrl} />
    <link rel="alternate" hreflang="en" href={enUrl} />
    <link rel="alternate" hreflang="x-default" href={zhUrl} />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:site_name" content="AI Free Plan" />
    <meta property="og:locale" content={lang === 'zh' ? 'zh_CN' : 'en_US'} />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />

    <title>{title}</title>

    <!-- JSON-LD -->
    {jsonLd && (
      <script
        type="application/ld+json"
        set:html={JSON.stringify(
          Array.isArray(jsonLd) ? jsonLd : [jsonLd]
        )}
      />
    )}
  </head>
  <body class="min-h-screen flex flex-col">
    <header class="bg-white border-b border-border sticky top-0 z-50">
      <nav class="max-w-6xl mx-auto px-4 py-3 flex items-center justify-between">
        <a href={`/${lang}`} class="text-xl font-bold text-primary">
          🤖 AI Free Plan
        </a>
        <div class="flex items-center gap-4">
          <a href={`/${lang}`} class="text-sm text-text-muted hover:text-text">
            {lang === 'zh' ? '首页' : 'Home'}
          </a>
          <a href={`/${lang === 'zh' ? 'en' : 'zh'}`} class="text-sm text-text-muted hover:text-text">
            {lang === 'zh' ? 'English' : '中文'}
          </a>
        </div>
      </nav>
    </header>

    <main class="flex-1 max-w-6xl mx-auto px-4 py-8 w-full">
      <slot />
    </main>

    <footer class="bg-white border-t border-border mt-auto">
      <div class="max-w-6xl mx-auto px-4 py-6 text-center text-sm text-text-muted">
        <p>&copy; {new Date().getFullYear()} AI Free Plan. {lang === 'zh' ? '免费AI工具大全，每日更新。' : 'Free AI tools directory, updated daily.'}</p>
      </div>
    </footer>
  </body>
</html>
