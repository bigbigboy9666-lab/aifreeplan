---
interface Props {
  title: string;
  excerpt: string;
  href: string;
  pinned?: boolean;
  lang?: 'zh' | 'en';
}

const { title, excerpt, href, pinned = false, lang = 'zh' } = Astro.props;
---

<a
  href={href}
  class:list={[
    'block rounded-xl border p-5 transition-all hover:shadow-lg hover:-translate-y-0.5 h-full flex flex-col',
    pinned ? 'border-primary/30 ring-1 ring-primary/10' : 'border-border'
  ]}
>
  <div class="flex items-center gap-2 mb-2">
    <span class="text-xl">📖</span>
    {pinned && (
      <span class="px-2 py-0.5 text-xs font-semibold rounded-full bg-primary text-white">
        {lang === 'zh' ? '置顶推荐' : 'Pinned'}
      </span>
    )}
  </div>
  <h3 class="text-base font-bold mb-1 line-clamp-2 flex-shrink-0">{title}</h3>
  <p class="text-sm text-text-muted line-clamp-2 flex-shrink-0 mb-3">{excerpt}</p>
  <div class="mt-auto text-sm font-medium text-primary">
    {lang === 'zh' ? '阅读全文' : 'Read More'} →
  </div>
</a>
