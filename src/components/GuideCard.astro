---
interface Props {
  title: string;
  excerpt: string;
  href: string;
  pinned?: boolean;
  lang?: 'zh' | 'en';
}

const { title, excerpt, href, pinned = false, lang = 'zh' } = Astro.props;
---

<a
  href={href}
  class:list={[
    'block rounded-xl border p-5 transition-all hover:shadow-lg hover:-translate-y-0.5',
    pinned ? 'border-primary/30 ring-1 ring-primary/10' : 'border-border'
  ]}
>
  <div class="flex items-start justify-between mb-2">
    <div class="flex items-center gap-2">
      <span class="text-xl">📖</span>
      {pinned && (
        <span class="px-2 py-0.5 text-xs font-semibold rounded-full bg-primary text-white">
          {lang === 'zh' ? '置顶推荐' : 'Pinned'}
        </span>
      )}
    </div>
  </div>
  <h3 class="text-base font-bold mb-1 line-clamp-2">{title}</h3>
  <p class="text-sm text-text-muted line-clamp-2">{excerpt}</p>
  <div class="mt-3 text-sm font-medium text-primary">
    {lang === 'zh' ? '阅读全文' : 'Read More'} →
  </div>
</a>
