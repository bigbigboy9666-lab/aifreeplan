---
interface Props {
  guide: Record<string, any>;
  locale: string;
}

const { guide, locale } = Astro.props;
const title = guide[`title_${locale}`] || guide.title_en;
const desc = guide[`description_${locale}`] || guide.description_en;
const tags = guide[`tags_${locale}`] || guide.tags_en || [];
const date = guide.date_modified || guide.date_published;
---

<a href={`/${locale}/guides/${guide.slug}`} class="guide-card" target="_blank" rel="noopener">
  <h3 class="guide-title">{title}</h3>
  <p class="guide-desc">{desc}</p>
  <div class="guide-meta">
    <span class="guide-date">{date}</span>
    <div class="guide-tags">
      {tags.slice(0, 3).map((tag: string) => (
        <span class="tag">{tag}</span>
      ))}
    </div>
  </div>
</a>
