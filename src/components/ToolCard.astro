---
import type { AITool } from '../types';

interface Props {
  tool: AITool;
  lang?: 'zh' | 'en';
}

const { tool, lang = 'zh' } = Astro.props;

const name = lang === 'zh' ? tool.name : tool.nameEn;
const description = lang === 'zh' ? tool.description : tool.descriptionEn;
const category = lang === 'zh' ? tool.categoryZh : tool.categoryEn;
const paidFrom = lang === 'zh' ? tool.paidFrom : tool.paidFromEn;

const refreshLabel: Record<string, string> = {
  daily: lang === 'zh' ? '每日' : 'Daily',
  weekly: lang === 'zh' ? '每周' : 'Weekly',
  monthly: lang === 'zh' ? '每月' : 'Monthly',
  'one-time': lang === 'zh' ? '一次性' : 'One-time',
  unknown: lang === 'zh' ? '未知' : 'Unknown',
};
---

<article class="flex flex-col bg-bg-card rounded-xl border border-border p-5 hover:shadow-lg transition-shadow h-full">
  <div class="mb-3">
    <div class="flex items-start justify-between mb-1">
      <h3 class="text-lg font-bold leading-tight">
        <a href={`/${lang}/tools/${tool.id}`} class="hover:text-primary">
          {name}
        </a>
      </h3>
      <span class="text-sm font-semibold text-accent whitespace-nowrap ml-2">⭐ {tool.rating}</span>
    </div>
    <span class="inline-block px-2 py-0.5 text-xs rounded-full bg-primary/10 text-primary">
      {category}
    </span>
  </div>

  <p class="text-sm text-text-muted mb-3 line-clamp-2 flex-shrink-0">{description}</p>

  <div class="mb-4 flex-shrink-0">
    <div class="flex items-center gap-2 text-sm mb-1">
      <span class="text-primary font-semibold">🆓</span>
      <span class="font-medium">{tool.freeTier.credits} {tool.freeTier.creditUnit}</span>
      <span class="text-text-muted text-xs">({refreshLabel[tool.freeTier.refreshPeriod]})</span>
    </div>
    {tool.freeTier.requiresCreditCard && (
      <div class="flex items-center gap-2 text-sm text-accent">
        <span>💳</span>
        <span>{lang === 'zh' ? '需要信用卡' : 'Credit card required'}</span>
      </div>
    )}
    {paidFrom && (
      <div class="text-sm text-text-muted">
        {lang === 'zh' ? '付费起步' : 'Paid from'}: {paidFrom}
      </div>
    )}
  </div>

  <a
    href={`/${lang}/tools/${tool.id}`}
    class="mt-auto block text-center bg-primary text-white text-sm font-medium rounded-lg px-4 py-2 hover:bg-primary-dark transition-colors"
  >
    {lang === 'zh' ? '查看详情' : 'View Details'}
  </a>
</article>
