---
interface Props {
  lang?: 'zh' | 'en';
}

const { lang = 'zh' } = Astro.props;
---

<section class="bg-gradient-to-r from-primary/10 to-secondary/10 rounded-2xl p-6 mt-8">
  <div class="max-w-2xl mx-auto text-center">
    <h3 class="text-xl font-bold mb-2">
      {lang === 'zh' ? '📬 获取每周免费AI工具推荐' : '📬 Get Weekly Free AI Tool Picks'}
    </h3>
    <p class="text-sm text-text-muted mb-4">
      {lang === 'zh'
        ? '订阅我们的邮件列表，每周精选最佳免费AI工具直送邮箱。'
        : 'Subscribe to our mailing list for curated free AI tool picks delivered weekly.'}
    </p>
    <a
      href="mailto:submit@aifreeplan.com?subject=%E8%AE%A2%E9%98%85%E9%82%AE%E4%BB%B6%E5%88%97%E8%A1%A8&body=%E8%AF%B7%E5%B0%86%E6%88%91%E8%AE%A2%E9%98%85%E5%88%B0%EF%BC%9A%0A%0A%E9%82%AE%E7%AE%B1%EF%BC%9A"
      class="inline-flex items-center gap-2 px-6 py-3 bg-primary text-white text-sm font-medium rounded-lg hover:bg-primary-dark transition-colors"
    >
      {lang === 'zh' ? '📧 订阅邮件列表' : '📧 Subscribe to Newsletter'}
    </a>
  </div>
</section>
