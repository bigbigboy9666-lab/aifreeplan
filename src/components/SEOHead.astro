---
interface Props {
  title: string;
  description: string;
  locale: string;
  canonical: string;
  ogImage?: string;
  jsonLd?: Record<string, any>[];
  noindex?: boolean;
  ogType?: string;
}

const {
  title,
  description,
  locale,
  canonical,
  ogImage = 'https://aifreeplan.com/og-default.png',
  jsonLd = [],
  noindex = false,
  ogType = 'website',
} = Astro.props;

// Normalize: remove trailing slash (except root)
function normalizeUrl(url: string): string {
  if (url === 'https://aifreeplan.com/' || url === 'https://aifreeplan.com') return 'https://aifreeplan.com';
  return url.replace(/\/+$/, '');
}

const normalizedCanonical = normalizeUrl(canonical);

const ogLocale = locale === 'zh' ? 'zh_CN' : 'en_US';
const xDefault = 'en';

// Build hreflang URLs: extract path after locale, rebuild for each locale
const pathAfterLocale = normalizedCanonical
  .replace(/^https:\/\/aifreeplan\.com\/(zh|en)/, '') || '';

const zhUrl = `https://aifreeplan.com/zh${pathAfterLocale}`;
const enUrl = `https://aifreeplan.com/en${pathAfterLocale}`;
const xDefaultUrl = `https://aifreeplan.com/${xDefault}${pathAfterLocale}`;
---

<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="baidu-site-verification" content="codeva-P0P3esmiMd" />
  <meta name="google-site-verification" content="" />
  <link rel="preconnect" href="https://www.googletagmanager.com" crossorigin />
  <link rel="dns-prefetch" href="https://www.googletagmanager.com" />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <meta name="theme-color" content="#6C5CE7" />

  <title>{title}</title>
  <meta name="description" content={description} />
  <link rel="canonical" href={normalizedCanonical} />

  <!-- Open Graph -->
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:url" content={normalizedCanonical} />
  <meta property="og:type" content={ogType} />
  <meta property="og:locale" content={ogLocale} />
  <meta property="og:image" content={ogImage} />
  <meta property="og:site_name" content="AIFreePlan" />

  <!-- Twitter Cards -->
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={title} />
  <meta name="twitter:description" content={description} />
  <meta name="twitter:image" content={ogImage} />

  <!-- Robots -->
  <meta name="robots" content={noindex ? 'noindex, follow' : 'index, follow'} />

  <!-- Hreflang: only for indexable pages -->
  {!noindex && (
    <>
      <link rel="alternate" hreflang="zh-CN" href={zhUrl} />
      <link rel="alternate" hreflang="en" href={enUrl} />
      <link rel="alternate" hreflang="x-default" href={xDefaultUrl} />
    </>
  )}

  <!-- JSON-LD -->
  {jsonLd.map((script) => (
    <script type="application/ld+json" set:html={JSON.stringify(script)} />
  ))}

  <!-- Google Analytics -->
  <script async src="https://www.googletagmanager.com/gtag/js?id=G-PYW0F8RL7R"></script>
  <script>
    window.dataLayer = window.dataLayer || [];
    function gtag(){dataLayer.push(arguments);}
    gtag('js', new Date());
    gtag('config', 'G-PYW0F8RL7R');
  </script>

  <!-- Global Styles -->
  <link rel="stylesheet" href="/global.css" />
</head>
