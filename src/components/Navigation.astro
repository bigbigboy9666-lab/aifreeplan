---
import { NAV_LINKS } from '@/utils/categories';

interface Props {
  locale: string;
  currentPath?: string;
}

const { locale, currentPath = '' } = Astro.props;
const isZh = locale === 'zh';
---

<nav class="navbar">
  <div class="nav-inner">
    <a href={`/${locale}`} class="logo">
      <span class="logo-mark">⚡</span>
      <span class="logo-text">AIFreePlan</span>
    </a>
    <div class="nav-links">
      {NAV_LINKS.map((link) => {
        const href = isZh ? link.href_zh : link.href_en;
        const label = isZh ? link.label_zh : link.label_en;
        const isActive = currentPath === href || currentPath.startsWith(href + '/');
        return (
          <a href={href} class={`nav-link ${isActive ? 'active' : ''}`}>{label}</a>
        );
      })}
      <div class="nav-divider"></div>
      <a href={isZh ? currentPath.replace('/zh/', '/en/') : currentPath.replace('/en/', '/zh/')} class="lang-btn">
        {isZh ? ' EN ' : ' 中文 '}
      </a>
    </div>
    <button class="mobile-menu-btn" id="mobileMenuBtn">☰</button>
  </div>
</nav>

<script>
  const btn = document.getElementById('mobileMenuBtn');
  const links = document.querySelector('.nav-links');
  if (btn && links) {
    btn.addEventListener('click', () => links.classList.toggle('open'));
  }
</script>
